# Шаблон переменных окружения. Скопируй этот файл в .env.local и заполни реальными значениями.
# .env.local НЕ коммитится в Git (добавлен в .gitignore автоматически).

# ─── Supabase ──────────────────────────────────────────────────────────────────
# URL твоего self-hosted Supabase (после запуска Docker на шаге 2)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
# Анонимный ключ — найдёшь в http://localhost:8000 после запуска Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=ваш-anon-key-здесь
# Сервисный ключ — только на сервере, НИКОГДА не передавать на клиент
SUPABASE_SERVICE_ROLE_KEY=ваш-service-role-key-здесь

# ─── Tinkoff Acquiring ─────────────────────────────────────────────────────────
# Получить в личном кабинете Тинькофф: https://business.tinkoff.ru/acquiring
TINKOFF_TERMINAL_KEY=ваш-terminal-key
TINKOFF_SECRET_KEY=ваш-secret-key
# Для тестирования используй тестовые ключи из документации Тинькофф

# ─── Email (Яндекс SMTP) ───────────────────────────────────────────────────────
# Инструкция: Яндекс → Настройки → Безопасность → Пароли приложений → создать для "Почта"
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=ваш-email@yandex.ru
SMTP_PASS=пароль-приложения-не-основной-пароль
SMTP_FROM="Gajin Delivery <ваш-email@yandex.ru>"

# ─── SMS (SMSC.ru) ─────────────────────────────────────────────────────────────
# Регистрация: https://smsc.ru
SMSC_LOGIN=ваш-логин-smsc
SMSC_PASSWORD=ваш-пароль-smsc
SMSC_SENDER=GAIJIN   # Имя отправителя (согласовывается с SMSC)

# ─── Приложение ────────────────────────────────────────────────────────────────
# Публичный URL сайта (для webhook-а Тинькофф и email-ссылок)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# В продакшне: NEXT_PUBLIC_SITE_URL=https://ваш-домен.ru

# ─── Безопасность ──────────────────────────────────────────────────────────────
# Случайная строка 32+ символа для подписи внутренних запросов
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=замени-на-случайную-строку-32-символа